linetype = "dashed",
colour = "gray70",
linewidth = 0.7) +
scale_fill_manual(values = c(untrt = "steelblue", trt = "firebrick")) +
labs(
title = "Detected Genes per samples",
subtitle = "Dashed Line = mean across samples",
x = NULL,
y = "Number of genes",
fill = "Treatment"
) +
theme_bw()
ggplot(det_s_df, aes(
x = reorder(sample, n_detected), # riordina sample per lib_size
y = n_detected,
fill = condition
)) +
geom_col(width = 0.7) +
geom_hline(
yintercept = mean(det_s_df$n_detected),
linetype = "dashed",
colour = "gray70",
linewidth = 0.7) +
scale_fill_manual(values = c(untrt = "steelblue", trt = "firebrick")) +
labs(
title = "Detected Genes per samples",
subtitle = "Dashed Line = mean across samples",
x = NULL,
y = "Number of genes",
fill = "Treatment"
) +
coord_flip() +
theme_bw()
